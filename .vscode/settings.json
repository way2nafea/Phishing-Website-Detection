{
  "CodeGPT.apiKey": "OpenAI",

  // ─── CSS / HTML Linter ────────────────────────────────────────────────────
  "css.validate": true,
  "less.validate": true,
  "scss.validate": true,

  "html.validate.styles": false,
  "html.validate.scripts": true,

  // ─── File Associations ────────────────────────────────────────────────────
  "files.associations": {
    "*.html": "html"
  },

  // ─── Editor comfort ───────────────────────────────────────────────────────
  "editor.formatOnSave": false,
  "editor.tabSize": 2
}